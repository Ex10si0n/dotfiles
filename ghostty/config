# [MARK] Font Configuration
font-family = "Maple Mono NF CN"
font-size = 13
font-feature = "calt, cv01, cv02, cv33, cv34, cv35, cv36, cv61, cv62, ss01, ss02, ss05, ss06, ss07, ss08"

# [MARK] Cursor & Shell
shell-integration = zsh
shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = true

# [MARK] Visuals
theme = Bright Lights
window-theme = dark

# [MARK] Window Layout
window-height = 32
window-width = 110
window-padding-balance = true
window-padding-x = 4 
window-padding-y = 4

# [MARK] Shader Rendering
custom-shader = shaders/cursor_sweep.glsl
custom-shader = shaders/ripple_cursor.glsl

# [MARK] Experiences
window-inherit-working-directory = true

# [MARK] Misc
confirm-close-surface = false
